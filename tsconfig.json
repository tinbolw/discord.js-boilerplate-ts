{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "target": "es2022",
    "module": "nodenext",
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "moduleResolution": "nodenext",
    "strict": true,
    "declaration": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "exclude": ["node_modules"],
  "include": ["src"]
}
